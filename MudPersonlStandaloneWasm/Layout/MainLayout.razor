@inherits LayoutComponentBase


<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Default" Fixed="true">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="d-flex align-center w-100 pa-0">
            <MudStack Spacing="0" Class="ml-3">
                <MudText Typo="Typo.h6"><b>Sammy Lastre Silveira</b></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Senior .NET Developer</MudText>
            </MudStack>
            <MudSpacer />
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="#about">About</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="#experience">Experience</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="#skills">Skills</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="#education">Education</MudButton>
                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           Href="https://www.linkedin.com/in/sammy-lastre-silveira-a22a0a199/"
                           Target="_blank"
                           StartIcon="@Icons.Custom.Brands.LinkedIn"
                           Class="ml-2">
                    Let's Connect
                </MudButton>
            </MudHidden>
            <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle" />
        </MudContainer>
    </MudAppBar>
    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>
@code {
    private bool _isDarkMode = true;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };
    }

    private void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Primary = "#1098B3",
        Secondary = "#6559D6",
        Black = "#0B1120",
        Background = "#F3F7FC",
        Surface = "#F8FBFF",
        AppbarText = "#0F172A",
        AppbarBackground = "rgba(243,247,252,0.88)",
        DrawerBackground = "#F8FBFF",
        TextPrimary = "#0F172A",
        TextSecondary = "#475569",
        ActionDefault = "#52647D",
        GrayLight = "#D8E2EF",
        GrayLighter = "#EEF3F9",
        Info = "#1D77D5",
        Success = "#127C4B",
        Warning = "#AD6500",
        Error = "#C33A56",
        LinesDefault = "#D7E2EF",
        Divider = "#D7E2EF",
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = "#58E1FF",
        PrimaryContrastText = "#07131E",
        Secondary = "#8E7CFF",
        Surface = "#111826",
        Background = "#0B1120",
        BackgroundGray = "#09101D",
        AppbarText = "#E7F4FF",
        AppbarBackground = "rgba(11,17,32,0.86)",
        DrawerBackground = "#0B1120",
        ActionDefault = "#8BA3BC",
        ActionDisabled = "#9999994d",
        ActionDisabledBackground = "#31405566",
        TextPrimary = "#E6F0FF",
        TextSecondary = "#93A6BE",
        TextDisabled = "#ffffff33",
        DrawerIcon = "#9EB4CC",
        DrawerText = "#9EB4CC",
        GrayLight = "#1A2638",
        GrayLighter = "#111826",
        Info = "#65B9FF",
        Success = "#45D89A",
        Warning = "#FFC164",
        Error = "#FF6E86",
        LinesDefault = "#22314A",
        TableLines = "#22314A",
        Divider = "#22314A",
        OverlayLight = "rgba(17,24,38,0.72)",
    };

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.LightMode,
        false => Icons.Material.Rounded.DarkMode,
    };
}


